<Window x:Class="JobTracker.WPF.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help — Job Application Tracker"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        Foreground="#e8e8e8"
        ResizeMode="CanResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="❓ Quick Help"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,16" Foreground="#e8e8e8"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Getting Started -->
                <TextBlock Text="📌 Getting Started" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#bb86fc"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#b0b0b0">
                    <Run Text="1. "/>
                    <Run Text="Dashboard" FontWeight="Bold"/>
                    <Run Text=" - Track all your job applications with table and Kanban views&#xA;"/>
                    <Run Text="2. "/>
                    <Run Text="New Application" FontWeight="Bold"/>
                    <Run Text=" - Add a new job application with role, company, and skills&#xA;"/>
                    <Run Text="3. "/>
                    <Run Text="Companies/Contacts" FontWeight="Bold"/>
                    <Run Text=" - Manage company and contact information&#xA;"/>
                    <Run Text="4. "/>
                    <Run Text="Settings" FontWeight="Bold"/>
                    <Run Text=" - Configure Obsidian vault sync path"/>
                </TextBlock>

                <!-- Keyboard Shortcuts -->
                <TextBlock Text="⌨️ Keyboard Shortcuts" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#bb86fc"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+D" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Dashboard" Foreground="#b0b0b0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+N" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="New Application" Foreground="#b0b0b0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+C" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Companies" Foreground="#b0b0b0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+T" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Contacts" Foreground="#b0b0b0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+S" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Skills" Foreground="#b0b0b0"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="F5" FontWeight="Bold" Foreground="#58a6ff"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="Refresh" Foreground="#b0b0b0"/>
                </Grid>

                <!-- Features -->
                <TextBlock Text="✨ Key Features" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#bb86fc"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#b0b0b0">
                    <Run Text="• Kanban board view" FontWeight="Bold"/>
                    <Run Text=" - Drag &amp; drop applications by status&#xA;"/>
                    <Run Text="• PDF extraction" FontWeight="Bold"/>
                    <Run Text=" - Auto-load job description from PDF&#xA;"/>
                    <Run Text="• Obsidian sync" FontWeight="Bold"/>
                    <Run Text=" - Auto-sync to markdown files in your vault&#xA;"/>
                    <Run Text="• Dark theme" FontWeight="Bold"/>
                    <Run Text=" - Full dark mode support&#xA;"/>
                    <Run Text="• Responsive tables" FontWeight="Bold"/>
                    <Run Text=" - Hover for full text, protected from accidental edits"/>
                </TextBlock>

                <!-- Repository -->
                <TextBlock Text="🔗 Repository" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#bb86fc"/>
                <Border Background="#2d2d2d" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="GitHub Repository" FontWeight="Bold" Margin="0,0,0,4" Foreground="#e8e8e8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#b0b0b0" Margin="0,0,0,8">
                            <Hyperlink NavigateUri="https://github.com/juandresrodca/job-application-tracker" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#58a6ff">
                                github.com/juandresrodca/job-application-tracker
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Text="Documentation" FontWeight="Bold" Margin="0,8,0,4" Foreground="#e8e8e8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#b0b0b0">
                            <Hyperlink NavigateUri="https://github.com/juandresrodca/job-application-tracker/blob/main/README.md" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#58a6ff">
                                View README on GitHub
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Tips -->
                <TextBlock Text="💡 Tips" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#bb86fc"/>
                <TextBlock TextWrapping="Wrap" Foreground="#b0b0b0">
                    <Run Text="• Use filters on the dashboard to find applications quickly&#xA;"/>
                    <Run Text="• Sync to Obsidian happens automatically after creating/editing&#xA;"/>
                    <Run Text="• Hover over text in tables to see full content&#xA;"/>
                    <Run Text="• Delete confirmations prevent accidental data loss"/>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="2" Content="Close" Width="100" HorizontalAlignment="Right"
                Background="#6200ee" Foreground="White" Padding="10,6"
                Margin="0,16,0,0" Click="Close_Click" Cursor="Hand"/>
    </Grid>
</Window>
