<Window x:Class="JobTracker.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Job Application Tracker"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/Images/app.ico"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="NewApplication"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Companies"/>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Contacts"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Skills"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar Nav ─────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo / Title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,32">
                    <!-- Logo: Bullseye target icon -->
                    <Viewbox Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Canvas Width="200" Height="200">
                            <!-- Outer ring - Red -->
                            <Ellipse Canvas.Left="5" Canvas.Top="5" Width="190" Height="190"
                                    Stroke="#F85149" StrokeThickness="8" Fill="Transparent"/>
                            <!-- Middle ring - Gray -->
                            <Ellipse Canvas.Left="38" Canvas.Top="38" Width="124" Height="124"
                                    Stroke="#8B949E" StrokeThickness="8" Fill="Transparent"/>
                            <!-- Horizontal line left -->
                            <Line X1="5" Y1="100" X2="65" Y2="100" Stroke="#30363D" StrokeThickness="4"/>
                            <!-- Horizontal line right -->
                            <Line X1="135" Y1="100" X2="195" Y2="100" Stroke="#30363D" StrokeThickness="4"/>
                            <!-- Inner circle - Green -->
                            <Ellipse Canvas.Left="70" Canvas.Top="70" Width="60" Height="60"
                                    Fill="#3FB950"/>
                            <!-- Center dot - White -->
                            <Ellipse Canvas.Left="94" Canvas.Top="94" Width="12" Height="12"
                                    Fill="#E6EDF3"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Text="Job Tracker"
                               Style="{StaticResource TitleText}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,0"/>
                    <TextBlock Text="{Binding WeekInfo}"
                               Style="{StaticResource SubtleText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button Content="🏠  Dashboard"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard"/>
                    <Button Content="➕  New Application"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="NewApplication"/>
                    <Button Content="🏢  Companies"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Companies"/>
                    <Button Content="👤  Contacts"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Contacts"/>
                    <Button Content="🎓  Skills"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Skills"/>
                    <Button Content="🔎  Discover"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Discover"/>
                    <Button Content="⚙️  Settings"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"/>
                </StackPanel>

                <!-- Help button -->
                <Button DockPanel.Dock="Bottom" Content="❓ Help"
                        Style="{StaticResource NavButton}"
                        Command="{Binding HelpCommand}"
                        Margin="8,0,8,8"/>

                <!-- Stats summary at the bottom of sidebar -->
                <Border DockPanel.Dock="Bottom" Margin="8,0,8,16"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="This Week" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding WeekStats}" Style="{StaticResource ValueText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ── Main Content Frame ─────────────────────────────────────────── -->
        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource BackgroundBrush}"/>
    </Grid>
</Window>
