<Page x:Class="JobTracker.WPF.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="700">
            <TextBlock Text="Settings" Style="{StaticResource PageTitleText}" Margin="0,0,0,24"/>

            <!-- Obsidian Vault -->
            <Border Style="{StaticResource FormCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📁 Obsidian Vault" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                    <TextBlock Text="Select the folder where your Obsidian vault is stored. Job applications will be synced as .md files."
                               Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <DockPanel>
                        <Button Content="Browse..." DockPanel.Dock="Right"
                                Command="{Binding BrowseVaultCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                        <TextBox Text="{Binding ObsidianVaultPath}"
                                 Style="{StaticResource FormTextBox}" IsReadOnly="True"/>
                    </DockPanel>
                    <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                        <Button Content="🔄 Sync All Applications Now"
                                Command="{Binding SyncAllCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <Button Content="🧹 Sync &amp; Clean Up Orphaned Files"
                                Command="{Binding SyncAndCleanupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Orientation="Horizontal">
                <Button Content="💾 Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"/>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
