<Page x:Class="JobTracker.WPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Title="Dashboard"
      Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <!-- Right-click interview menu. Rule 1: no interview yet → a single "set first"
             option. Rule 2: one already exists → "new instance" + "modify date". Visibility
             is driven by the row's InterviewCount so the two states never overlap. -->
        <ContextMenu x:Key="RowContextMenu">
            <MenuItem Header="📅 Set first interview" Click="SetInterview_Click"
                      Visibility="{Binding InterviewCount, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=zero}"/>
            <MenuItem Header="➕ Set new interview" Click="SetInterview_Click"
                      Visibility="{Binding InterviewCount, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=positive}"/>
            <MenuItem Header="✏️ Modify interview date" Click="ModifyInterview_Click"
                      Visibility="{Binding InterviewCount, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=positive}"/>
        </ContextMenu>

        <Style x:Key="RowWithInterviewMenu" TargetType="DataGridRow"
               BasedOn="{StaticResource MainDataGridRowStyle}">
            <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + Stats -->
            <RowDefinition Height="Auto"/>  <!-- Filters toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Upcoming interviews strip -->
            <RowDefinition Height="*"/>     <!-- Data grid -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header + Stat Cards ───────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding DashboardTitle}"
                           Style="{StaticResource PageTitleText}"/>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Stat cards -->
            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalApplications}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Total" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveApplications}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Active" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding InterviewCount}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Interviews" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ResponseRate}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Response" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding OfferRate}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Offer Rate" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}"
                        ToolTip="Active applications with no movement for 14+ days">
                    <StackPanel>
                        <TextBlock Text="{Binding FollowUpCount}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Follow up" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <!-- ── Filters + Actions Toolbar ────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBox}"
                         Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AllStatuses}"
                          SelectedItem="{Binding StatusFilter}"
                          SelectedIndex="0"
                          Style="{StaticResource FilterCombo}"
                          Width="140" Margin="0,0,8,0"/>

                <ComboBox Grid.Column="2"
                          Style="{StaticResource FilterCombo}"
                          SelectedValue="{Binding SortBy, Mode=TwoWay}"
                          SelectedValuePath="Tag"
                          Width="130" Margin="0,0,8,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Date" Tag="AppliedDate"/>
                    <ComboBoxItem Content="Company" Tag="Company"/>
                    <ComboBoxItem Content="Days Active" Tag="Days"/>
                    <ComboBoxItem Content="Status" Tag="Status"/>
                </ComboBox>

                <Button Grid.Column="3" Content="✕ Clear"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4" Content="📊 Toggle View"
                        Command="{Binding ToggleViewCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        Content="{Binding IsWeekView, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Global Overview|This Week'}"
                        Command="{Binding ToggleDashboardViewCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="6" Content="➕ New Application"
                        Command="{Binding NewApplicationCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <!-- ── Upcoming interviews ────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16"
                Visibility="{Binding HasUpcomingInterviews, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="📅 Upcoming interviews" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding UpcomingInterviews}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="10,7" Margin="0,0,10,6" MaxWidth="280">
                                <Border.ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Interviewer, StringFormat='Interviewer: {0}'}"/>
                                        <TextBlock Text="{Binding LocationOrLink}"/>
                                        <TextBlock Text="{Binding Notes}"/>
                                    </StackPanel>
                                </Border.ToolTip>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="4" Padding="5,1" Margin="0,0,7,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#14A38E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Background" Value="#E5484D"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTomorrow}" Value="True">
                                                            <Setter Property="Background" Value="#E0A100"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding WhenText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="{Binding Type}" Style="{StaticResource SubtleText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding RoleName, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding CompanyName, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── Table View ─────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding FilteredApplications}"
                  SelectedItem="{Binding SelectedApplication}"
                  Style="{StaticResource MainDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeColumns="False" CanUserResizeRows="False"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  RowStyle="{StaticResource RowWithInterviewMenu}"
                  Visibility="{Binding IsKanbanView, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Role" Width="*" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RoleName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding RoleName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Company" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CompanyName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Status" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Applied" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AppliedDate, StringFormat='yyyy-MM-dd'}" TextTrimming="CharacterEllipsis" ToolTip="{Binding AppliedDate, StringFormat='yyyy-MM-dd'}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Days" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DaysSinceApplication}" TextTrimming="CharacterEllipsis" ToolTip="{Binding DaysSinceApplication}"/>
                                <TextBlock Text=" ⏰" FontSize="11"
                                           Visibility="{Binding NeedsFollowUp, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.ToolTip>
                                        <TextBlock Text="{Binding DaysSinceLastActivity, StringFormat='No activity for {0} days — time to follow up'}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Contact" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ContactName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ContactName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Remote" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsRemote}" TextTrimming="CharacterEllipsis" ToolTip="{Binding IsRemote}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Salary" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SalaryRange}" TextTrimming="CharacterEllipsis" ToolTip="{Binding SalaryRange}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"
                                        Command="{Binding DataContext.EditApplicationCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Style="{StaticResource GridActionButton}" Margin="0,0,4,0"/>
                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteSelectedCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Style="{StaticResource DangerButton}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Kanban Board View ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsKanbanView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding KanbanColumns}" Margin="0,4,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Margin="0,0,12,0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="12" Opacity="0.4"/>
                            </Border.Effect>
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Background="{StaticResource CardBrush}"
                                        Padding="12,8" CornerRadius="8,8,0,0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="{Binding Items.Count, StringFormat=' ({0})'}"
                                                   Style="{StaticResource SubtleText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource CardBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="10,8" Margin="0,0,0,8"
                                                        ContextMenu="{StaticResource RowContextMenu}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding RoleName}"
                                                                   Style="{StaticResource TitleText}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding CompanyName}"
                                                                   Style="{StaticResource SubtleText}" Margin="0,2,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding DaysSinceApplication, StringFormat='{}{0}d ago'}"
                                                                       Style="{StaticResource LabelText}"/>
                                                            <TextBlock Text=" · ⏰ follow up" FontSize="10" Foreground="#E0A100"
                                                                       Visibility="{Binding NeedsFollowUp, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                       ToolTip="{Binding DaysSinceLastActivity, StringFormat='No activity for {0} days'}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Status Bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" Padding="8,4" Margin="0,8,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"/>
                <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
