<Page x:Class="JobTracker.WPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Title="Dashboard"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + Stats -->
            <RowDefinition Height="Auto"/>  <!-- Filters toolbar -->
            <RowDefinition Height="*"/>     <!-- Data grid -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header + Stat Cards ───────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding DashboardTitle}"
                           Style="{StaticResource PageTitleText}"/>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Stat cards -->
            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalApplications}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Total" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveApplications}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Active" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding InterviewCount}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Interviews" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ResponseRate}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Response" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding OfferRate}" Style="{StaticResource StatNumber}"/>
                        <TextBlock Text="Offer Rate" Style="{StaticResource StatLabel}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <!-- ── Filters + Actions Toolbar ────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBox}"
                         Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AllStatuses}"
                          SelectedItem="{Binding StatusFilter}"
                          SelectedIndex="0"
                          Style="{StaticResource FilterCombo}"
                          Width="140" Margin="0,0,8,0"/>

                <ComboBox Grid.Column="2"
                          Style="{StaticResource FilterCombo}"
                          SelectedValue="{Binding SortBy, Mode=TwoWay}"
                          SelectedValuePath="Tag"
                          Width="130" Margin="0,0,8,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Date" Tag="AppliedDate"/>
                    <ComboBoxItem Content="Company" Tag="Company"/>
                    <ComboBoxItem Content="Days Active" Tag="Days"/>
                    <ComboBoxItem Content="Status" Tag="Status"/>
                </ComboBox>

                <Button Grid.Column="3" Content="✕ Clear"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4" Content="📊 Toggle View"
                        Command="{Binding ToggleViewCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        Content="{Binding IsWeekView, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Global Overview|This Week'}"
                        Command="{Binding ToggleDashboardViewCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="6" Content="➕ New Application"
                        Command="{Binding NewApplicationCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <!-- ── Table View ─────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredApplications}"
                  SelectedItem="{Binding SelectedApplication}"
                  Style="{StaticResource MainDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  Visibility="{Binding IsKanbanView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Role"    Binding="{Binding RoleName}"    Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="140"/>
                <DataGridTemplateColumn Header="Status" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Applied" Binding="{Binding AppliedDate, StringFormat='yyyy-MM-dd'}" Width="100"/>
                <DataGridTextColumn Header="Days"    Binding="{Binding DaysSinceApplication}" Width="60"/>
                <DataGridTextColumn Header="Contact" Binding="{Binding ContactName}"  Width="130"/>
                <DataGridTextColumn Header="Remote"  Binding="{Binding IsRemote}"     Width="70"/>
                <DataGridTextColumn Header="Salary"  Binding="{Binding SalaryRange}"  Width="110"/>
                <DataGridTemplateColumn Header="Actions" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"
                                        Command="{Binding DataContext.EditApplicationCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Style="{StaticResource GridActionButton}" Margin="0,0,4,0"/>
                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteSelectedCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Style="{StaticResource DangerButton}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Kanban Board View ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsKanbanView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding KanbanColumns}" Margin="0,4,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Margin="0,0,12,0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Background="{StaticResource CardBrush}"
                                        Padding="12,8" CornerRadius="8,8,0,0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="{Binding Items.Count, StringFormat=' ({0})'}"
                                                   Style="{StaticResource SubtleText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource CardBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="10,8" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding RoleName}"
                                                                   Style="{StaticResource TitleText}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding CompanyName}"
                                                                   Style="{StaticResource SubtleText}" Margin="0,2,0,0"/>
                                                        <TextBlock Text="{Binding DaysSinceApplication, StringFormat='{}{0}d ago'}"
                                                                   Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Status Bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="8,4" Margin="0,8,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"/>
                <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
