<Page x:Class="JobTracker.WPF.Views.Pages.CompaniesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Companies" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🏢 Companies"
                   Style="{StaticResource PageTitleText}" Margin="0,0,0,16"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBox}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="✏️ Edit"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="🗑 Delete"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="➕ New Company"
                        Command="{Binding NewCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredCompanies}"
                      SelectedItem="{Binding SelectedCompany}"
                      Style="{StaticResource MainDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeColumns="False" CanUserResizeRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="*" MinWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Industry" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Industry}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Industry}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Location" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Location}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Location}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Website" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Website}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Website}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Inline edit panel — slides in when IsFormVisible = true -->
            <Border Grid.Column="1" Width="340"
                    Style="{StaticResource FormCard}"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Company Details" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>

                    <TextBlock Text="Name *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Text="Industry" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditIndustry, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Text="Location" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditLocation, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Text="Website" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditWebsite, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MultiLineTextBox}" Height="80" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="💾 Save"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="8,4" Margin="0,8,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"/>
                <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
