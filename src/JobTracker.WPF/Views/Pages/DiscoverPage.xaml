<Page x:Class="JobTracker.WPF.Views.Pages.DiscoverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Title="Discover"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + mode toggle -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar (per mode) -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Discover Jobs" Style="{StaticResource PageTitleText}"/>
                <TextBlock Style="{StaticResource SubtleText}" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="Fetch roles from a Greenhouse board, or browse any job site with the co-pilot: it reads the posting, highlights your skills on the page, and tracks it in one click."/>
            </StackPanel>
            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                      Content="🧭 Browser co-pilot mode"
                      Style="{StaticResource FormCheckBox}"
                      IsChecked="{Binding IsBrowserMode}"/>
        </Grid>

        <!-- ══════════════ BOARDS MODE (Greenhouse API) ══════════════ -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16"
                Visibility="{Binding IsBoardsMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding BoardSlug, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBox}"
                         ToolTip="Greenhouse board name — usually the company name in lowercase (e.g. monzo, stripe, gitlab)"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="🔎 Fetch jobs"
                        Command="{Binding FetchCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsBoardsMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource TitleText}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding Location}" Style="{StaticResource SubtleText}"/>
                                        <TextBlock Text="{Binding UpdatedText, StringFormat=' · updated {0}'}"
                                                   Style="{StaticResource SubtleText}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RelevanceText}"
                                               Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12"
                                               Foreground="#2DBDA6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="🌐 Open"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0"
                                            Click="OpenJob_Click"
                                            Tag="{Binding}"/>
                                    <Button Content="➕ Track"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="TrackJob_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ══════════════ BROWSER CO-PILOT MODE ══════════════ -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="0,0,0,16"
                Visibility="{Binding IsBrowserMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="◀" Click="BrowserBack_Click"
                        Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,8,0"
                        ToolTip="Back"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SitePresets}"
                          SelectedItem="{Binding SelectedSite}"
                          Style="{StaticResource FilterCombo}"
                          Width="150" Margin="0,0,8,0"
                          ToolTip="Job site presets"/>
                <TextBox Grid.Column="2"
                         Text="{Binding CurrentUrl, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBox}"
                         KeyDown="UrlBox_KeyDown"
                         ToolTip="Address — press Enter to navigate"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="Go" Click="BrowserGo_Click"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Visibility="{Binding IsBrowserMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="*" MinWidth="270"/>
            </Grid.ColumnDefinitions>

            <!-- Embedded browser with tabs: popups ("Apply on company site") open as a
                 new tab, so the co-pilot panel always works on whatever tab is active -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Margin="0,0,12,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                            Padding="4" CornerRadius="8,8,0,0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TabStrip">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5" Padding="8,4" Margin="0,0,4,0" Cursor="Hand"
                                                MouseLeftButtonDown="Tab_Click" Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" MaxWidth="150"
                                                           TextTrimming="CharacterEllipsis" FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding Title}"/>
                                                <TextBlock Text="  ✕" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                                                           MouseLeftButtonDown="TabClose_Click" Tag="{Binding}"
                                                           ToolTip="Close tab"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Grid x:Name="BrowserHost">
                        <!-- WebView2 tabs are added here in code-behind; this stays on top -->
                        <Border x:Name="WebViewError" Visibility="Collapsed" Panel.ZIndex="99"
                                Background="{StaticResource SurfaceBrush}" Padding="24">
                            <StackPanel VerticalAlignment="Center" MaxWidth="420">
                                <TextBlock Text="Browser engine not available" Style="{StaticResource SectionHeader}"/>
                                <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,8,0,0"
                                           Text="The co-pilot needs the Microsoft Edge WebView2 Runtime, which is pre-installed on up-to-date Windows 10/11. Install it from Microsoft's site (search 'WebView2 Runtime download') and reopen this page."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Co-pilot panel -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="🧭 Co-pilot" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding CopilotStatus}" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,6,0,10"/>
                        <Button Content="📖 Scan page" Click="ScanPage_Click"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0"
                                Visibility="{Binding HasScan, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ScannedTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ScannedCompany}" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,8"/>
                        <TextBlock Text="{Binding ScanMatchText}" Foreground="#2DBDA6"
                                   TextWrapping="Wrap" FontSize="12.5"/>
                        <Button Content="🖊 Highlight my skills on page" Click="Highlight_Click"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,12,0,0"/>
                        <Button Content="➕ Track this job" Click="TrackScanned_Click"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" VerticalAlignment="Bottom"
                               Style="{StaticResource SubtleText}" FontSize="11" TextWrapping="Wrap"
                               Text="The co-pilot only reads the page you are viewing, locally — nothing is sent anywhere."/>
                    <Border/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="8,4" Margin="0,8,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                           Visibility="{Binding IsBoardsMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Text="{Binding CopilotStatus}" Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                           Visibility="{Binding IsBrowserMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
